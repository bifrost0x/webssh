# webssh configuration — copy to .env and adjust.
#
# Real environment variables (Docker, systemd, shell exports) ALWAYS take
# precedence over values in this file, so .env is safe to use alongside them.
# Lines starting with # are comments. Do NOT commit your real .env.

# ─── Security (required in production) ───────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Enable Flask debug mode. NEVER set to True in production.
DEBUG=False

# ─── Server ──────────────────────────────────────────────────────────────────
# Bind address. Use 0.0.0.0 to accept external connections (e.g. behind a proxy).
HOST=127.0.0.1
PORT=5000

# Directory for the database, keys, logs and per-user data.
DATA_DIR=./data

# URL sub-path when deployed under a sub-folder, e.g. /webssh (leave empty otherwise).
APPLICATION_ROOT=

# ─── Reverse proxy ───────────────────────────────────────────────────────────
# Number of trusted reverse-proxy layers in front of the app (0 = none).
# Set to 1 when behind a single proxy (Traefik, nginx, Caddy) so the real
# client IP is read from X-Forwarded-For.
TRUSTED_PROXIES=0

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, e.g. https://ssh.example.com
# Leave empty to default to localhost only.
CORS_ORIGINS=
# Allow wildcard CORS (*) in production. Only for trusted networks (homelab).
ALLOW_CORS_WILDCARD=false

# ─── Session / cookies ───────────────────────────────────────────────────────
# Idle SSH session timeout in seconds (default 1800 = 30 min).
SESSION_TIMEOUT=1800
# Force the Secure flag on cookies. Auto (HTTPS-only) in production if unset.
# Set to false when terminating TLS at a proxy that forwards plain HTTP.
# SESSION_COOKIE_SECURE=

# ─── Features ────────────────────────────────────────────────────────────────
# Allow new account registration via the web UI.
REGISTRATION_ENABLED=True
# Block SSH connections to loopback/link-local addresses (SSRF protection).
# Keep false for homelab use where connecting to internal IPs is intended.
BLOCK_INTERNAL_SSH=false

# Allow persistent sessions through tmux installed on the remote SSH host.
TMUX_ENABLED=false
# Preselect persistent tmux sessions in the connection dialog.
TMUX_DEFAULT=false
# Prefix for tmux session names created on remote hosts.
TMUX_SESSION_PREFIX=webssh

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATELIMIT_ENABLED=True
RATELIMIT_LOGIN_LIMIT=5 per minute
RATELIMIT_DEFAULT=200 per hour
# Storage backend for rate-limit counters.
#   memory://  (default) — per-process, no external dependency.
#   redis://host:port/db — counters survive app restarts while Redis is running.
# Redis does not make multi-worker deployments safe; live SSH state remains
# in-process and the application must continue to run with one worker.
# If Redis is unreachable, requests use an in-memory fallback and the app
# periodically retries Redis without delaying every request.
# RATELIMIT_STORAGE_URL=memory://

# ─── File transfer limits (bytes) ────────────────────────────────────────────
# Max single-file download (default 100 MB).
MAX_DOWNLOAD_SIZE=104857600
# Max folder ZIP download (default 500 MB).
MAX_ZIP_DOWNLOAD_SIZE=524288000
