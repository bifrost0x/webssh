# Git
.git/
.github/
.gitignore

# Virtual environment
venv/
env/
ENV/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment and secrets - CRITICAL
.env
.env.local
.env.production

# User data directory - contains sensitive data
data/

# AI assistant files & internal docs (must never end up in the public image)
CLAUDE.md
.claude/
plans/

# Knowledge graph (dev artifact; the public Pages graph is rebuilt in CI)
graphify-out/

# Logs
*.log
logs/

# Node / frontend tooling (vendored assets live in static/vendor/ and are
# already committed; node_modules is only needed to regenerate them).
node_modules/

# Distribution / packaging
build/
dist/
*.egg-info/

# Documentation (not needed in container)
README.md
docs/

# Test files
tests/
test_*.py
*_test.py

# Backup files
*.bak
*.backup
*.orig
